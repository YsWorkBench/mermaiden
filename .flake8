[flake8]
max-line-length = 88
extend-ignore =
    # E203: whitespace before ':'
    E203,
    # W503: line break before binary operator
    W503,
    # E501: line too long (handled by black)
    E501
    # labmda stop vor visibility
    E731
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    .mypy_cache,
    .pytest_cache
per-file-ignores =
    # Tests can have longer lines, unused imports, and simplified docstring rules
    tests/*:D100,D103,E501,F401,F811,E731
    # __init__.py files can have unused imports
    __init__.py:F401
max-complexity = 30
import-order-style = google
application-import-names =
    ast_logic,
    discovery,
    generate,
    inventory,
    mermaiden,
    models,
    paths,
    render
